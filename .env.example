# =================================================================
# Job AI Suite - Environment Template (Public)
# =================================================================

# 1. Database Configuration (REQUIRED)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jobs
DB_USER=user
DB_PASSWORD=your_password

# 2. Local Paths (REQUIRED)
CHROME_PATH=/usr/bin/google-chrome-stable
CHROME_PROFILE_DIR=./chrome_profile

# 3. Service Ports (REQUIRED)
BACKEND_PORT=8888
FRONTEND_PORT=5175

# 4. LLM Configuration (REQUIRED)
GEMMA_API_BASE=http://localhost:11434/v1
GEMMA_API_KEY=ollama
GEMMA_MODEL_NAME=gemma3:12b-it-qat

QWEN_API_BASE=http://localhost:8000/v1
QWEN_API_KEY=vllm
QWEN_MODEL_NAME=Qwen/Qwen3-8B-AWQ

GLM_API_BASE=https://coding.dashscope.aliyuncs.com/v1
GLM_API_KEY=your_key_here
GLM_MODEL_NAME=glm-5

# 5. Frontend API Configuration
VITE_API_BASE_URL=http://localhost:8888

# 6. Script Runtime Configuration
CONDA_ENV=agent
USE_CONDA=true

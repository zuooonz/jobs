{
    "identity": {
        "profiles": [
            "~/path/to/your/intention.md",
            "~/path/to/your/resume.md"
        ]
    },
    "storage": {
        "notes_dir": "~/Documents/notes/jobs",
        "chrome_profile_dir": "./chrome_profile"
    },
    "strategy": {
        "evaluator": {
            "hard_blacklist": ["客服", "保安", "保洁"],
            "prompt_template": "作为一个资深HR专家..."
        },
        "filtration": {
            "black_keywords": ["销售", "管培生"],
            "min_salary": 15,
            "target_cities": ["北京", "上海"]
        }
    },
    "ui": {
        "clusters": {
            "1_AI": "AI 基础设施"
        },
        "categorization_rules": [
            {
                "id": "1_AI",
                "keywords": ["infra", "架构"]
            }
        ]
    },
    "tools": {
        "obsidian": { "threshold": 80 },
        "resume_tailor": { "prompt_template": "..." }
    },
    "scraper": {
        "keywords": ["AI算法工程师"],
        "batch_size": 10,
        "city": "010"
    }
}